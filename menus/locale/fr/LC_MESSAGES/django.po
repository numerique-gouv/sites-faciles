msgid "Page"
msgstr "Page"

msgid "External URL"
msgstr "URL externe"

msgid "Document"
msgstr "Document"

msgid "Link type"
msgstr "Type de lien"

msgid "Select the type of link."
msgstr "Choisissez le type de lien."

msgid "Link label"
msgstr "Libellé du lien"

msgid ""
"If this field is empty, the title of the linked page or document will be "
"used."
msgstr ""
"Si ce champ est vide, le titre de la page ou du document lié sera utilisé."

msgid "Icon"
msgstr "Icône"

msgid "See the whole section"
msgstr "Voir tout la rubrique"

msgid "Submenu label"
msgstr "Libellé du sous-menu"

msgid "Links"
msgstr "Liens"

msgid "The recommended maximum number of links in a single submenu is 8."
msgstr "Le nombre de liens maximum recommandé dans un sous-menu est de 8."

msgid "Column label"
msgstr "Libellé de la colonne"

msgid "Mega menu label"
msgstr "Libellé du méga menu"

msgid "Description"
msgstr "Description"

msgid "Main link"
msgstr "Lien principal"

msgid "Column"
msgstr "Colonne"

msgid "Columns"
msgstr "Colonnes"

msgid "Link"
msgstr "Lien"

msgid "Submenu"
msgstr "Sous-menu"

msgid "Mega menu"
msgstr "Méga menu"

msgid "Site"
msgstr "Site"

msgid "Menu items"
msgstr "Éléments de menu"

msgid "The top menu of the website, displayed in the top right corner."
msgstr "Le menu du haut du site, situé dans le coin en haut à droite."

msgid "There can only be one top menu per site and per locale."
msgstr "Il ne peut y avoir qu'un menu du haut par site et par langue."

msgid "It can contain up to three links."
msgstr "Il peut contenir jusqu'à trois liens."

msgid "Top menu"
msgstr "Menu du haut"

msgid "Top menus"
msgstr "Menus du haut"

#, python-brace-format
msgid "Top menu for site {hostname}"
msgstr "Menu du haut pour le site {hostname}"

msgid ""
"The footer bottom menu of the website, displayed at the bottom of the footer."
msgstr "Le menu du bas du pied de page du site."

msgid "There can only be one footer bottom menu per site and per locale."
msgstr "Il ne peut y avoir qu'un menu de ce type par site et par langue."

msgid ""
"This menu contains the legal links: Terms of Service, Privacy Policy, etc."
msgstr ""
"Ce menu contient les liens vers les pages légales : conditions "
"d'utilisation, politique de confidentialité, etc."

msgid "Footer bottom menu"
msgstr "Menu du bas du pied de page"

msgid "Footer bottom menus"
msgstr "Menus du bas du pied de page"

#, python-brace-format
msgid "Footer bottom menu for site {hostname}"
msgstr "Menu du bas du pied de page pour le site {hostname}"

msgid "The recommended maximum number of items in the main menu is 8."
msgstr "Le nombre de liens maximum recommandé dans le menu principal est de 8."

msgid "The main menu of the website, displayed in the main navigation area."
msgstr ""
"Le menu principal du site, situé dans la zone de navigation principale."

msgid "There can only be one main menu per site and per locale."
msgstr "Il ne peut y avoir qu'un menu de ce type par site et par langue."

msgid "It can contain links, submenus, and mega menus."
msgstr "Il peut contenir des liens, des sous-menus et des méga-menus."

msgid "It is recommended to avoid mixing submenus and mega menus."
msgstr ""
"Il est recommandé de ne pas utiliser en même temps des sous-menus et des "
"méga-menus."

msgid "Main menu"
msgstr "Menu principal"

msgid "Main menus"
msgstr "Menus principaux"

#, python-brace-format
msgid "Main menu for site {hostname}"
msgstr "Menu principal pour le site {hostname}"

msgid "Opens a new window"
msgstr "Ouvre une nouvelle fenêtre"

msgid "Close"
msgstr "Fermer"

